{
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "mode": "plan"
      },
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "collaboration_panel": {
    "dock": "right"
  },
  "ui_font_family": "Monaco",
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "CSS": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    }
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    },
    "biome": {
      "settings": {
        "require_config_file": true
      },
      "binary": {
        "path": "/opt/homebrew/bin/biome",
        "arguments": ["lsp-proxy"]
      }
    }
  },
  "preview_tabs": {
    "enable_preview_from_project_panel": false
  },
  "use_system_window_tabs": true,
  "debugger": {
    "button": true
  },
  "diagnostics": {
    "button": false
  },
  "status_bar": {
    "active_language_button": true
  },
  "language_models": {
    "openai_compatible": {
      "Z.ai": {
        "api_url": "https://api.z.ai/api/coding/paas/v4",
        "available_models": [
          {
            "name": "GLM-5.1",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          }
        ]
      },
      "opencode": {
        "api_url": "https://opencode.ai/zen/v1/chat/completions",
        "available_models": [
          {
            "name": "big-pickle",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          }
        ]
      }
    }
  },
  "current_line_highlight": "line",
  "active_pane_modifiers": {
    "border_size": 0.0,
    "inactive_opacity": 1.0
  },
  "show_edit_predictions": true,
  "icon_theme": "Warm Charmed Icons",
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager"
  },
  "disable_ai": false,
  "theme": {
    "mode": "dark",
    "light": "Atomize",
    "dark": "One Dark Pro"
  },
  "tab_size": 2,
  "preferred_line_length": 80,
  "soft_wrap": "prefer_line",
  "show_wrap_guides": true,
  "wrap_guides": [80, 100],
  "buffer_font_size": null,
  "buffer_font_family": "Monaco",
  "ui_font_fallbacks": ["Inter", ".SystemUIFont"],
  "ui_font_size": 16,
  "vim_mode": false,
  "terminal": {
    "button": true,
    "font_family": "Monaco",
    "blinking": "off",
    "font_size": 16,
    "working_directory": "current_project_directory",
    "dock": "bottom"
  },
  "file_finder": {
    "modal_max_width": "medium"
  },
  "tabs": {
    "file_icons": false,
    "close_position": "right",
    "git_status": true,
    "activate_on_close": "history",
    "show_close_button": "hover",
    "show_diagnostics": "errors"
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show": true,
    "show_nav_history_buttons": true,
    "show_tab_bar_buttons": true
  },
  "auto_install_extensions": {
    "html": true,
    "astro": true,
    "atomize": true,
    "emmet": true,
    "env": true,
    "jsonnet": true,
    "toml": true
  },
  "use_autoclose": true,
  "format_on_save": "on",
  "autosave": "off",
  "formatter": [
    {
      "language_server": {
        "name": "eslint"
      }
    },
    {
      "external": {
        "command": "prettier",
        "arguments": ["--stdin-filepath", "{buffer_path}"]
      }
    }
  ],
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true
    }
  },
  "journal": {
    "path": "~",
    "hour_format": "hour12"
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
  "calls": {
    "mute_on_join": true,
    "share_on_join": false
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": false,
    "show_user_picture": true,
    "show_sign_in": true,
    "show_menus": true
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "show_turn_stats": true,
    "favorite_models": [
      {
        "provider": "Z.ai",
        "model": "glm-4.6"
      },
      {
        "provider": "Z.ai",
        "model": "GLM-4.7"
      }
    ],
    "default_model": {
      "provider": "Z.ai",
      "model": "GLM-5.1"
    },
    "commit_message_model": {
      "provider": "opencode",
      "model": "big-pickle"
    },
    "thread_summary_model": {
      "provider": "openai",
      "model": "gpt-4o-mini"
    },
    "enable_feedback": false,
    "message_editor_min_lines": 10,
    "use_modifier_to_send": true,
    "play_sound_when_agent_done": "always",
    "single_file_review": true,
    "profiles": {
      "ask": {
        "name": "Ask",
        "tools": {
          "search_web": true,
          "contents": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": false,
          "grep": true,
          "thinking": true
        },
        "enable_all_context_servers": false,
        "context_servers": {}
      },
      "write": {
        "name": "Write",
        "tools": {
          "search_web": false,
          "copy_path": true,
          "create_directory": true,
          "create_file": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "grep": true,
          "terminal": false,
          "thinking": true,
          "open": true
        },
        "enable_all_context_servers": true,
        "context_servers": {}
      }
    },
    "default_profile": "write",
    "default_width": 420
  },
  "git_panel": {
    "dock": "left",
    "tree_view": false,
    "default_width": 240
  },
  "outline_panel": {
    "button": false,
    "default_width": 240,
    "dock": "right",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "indent_guides": {
      "show": "always"
    },
    "scrollbar": {
      "show": null
    }
  },
  "project_panel": {
    "hide_root": false,
    "button": true,
    "default_width": 200,
    "file_icons": true,
    "dock": "left",
    "folder_icons": true,
    "git_status": true,
    "indent_size": 14,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "show_diagnostics": "all",
    "scrollbar": {
      "show": "never"
    },
    "indent_guides": {
      "show": "never"
    }
  },
  "search": {
    "button": true,
    "whole_word": true,
    "case_sensitive": true,
    "include_ignored": false,
    "regex": false
  },
  "seed_search_query_from_cursor": "selection",
  "completions": {
    "words": "enabled",
    "lsp": true,
    "lsp_fetch_timeout_ms": 0,
    "lsp_insert_mode": "replace_suffix"
  },
  "gutter": {
    "line_numbers": true,
    "runnables": false,
    "breakpoints": false,
    "folds": true,
    "min_line_number_digits": 1
  },
  "minimap": {
    "show": "never",
    "thumb": "hover",
    "thumb_border": "left_open",
    "current_line_highlight": "all"
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/node_modules"
  ]
}
