{
  "search_wrap": true,
  "relative_line_numbers": "wrapped",
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "mode": "build"
      },
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "collaboration_panel": {
    "dock": "right"
  },
  "ui_font_family": "Monaco",
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "CSS": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    }
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    },
    "biome": {
      "settings": {
        "require_config_file": true
      },
      "binary": {
        "path": "/opt/homebrew/bin/biome",
        "arguments": ["lsp-proxy"]
      }
    }
  },
  "preview_tabs": {
    "enable_preview_from_project_panel": false
  },
  "use_system_window_tabs": true,
  "debugger": {
    "button": true
  },
  "diagnostics": {
    "button": false
  },
  "status_bar": {
    "active_language_button": true
  },
  "language_models": {
    "openai_compatible": {
      "Z.ai": {
        "api_url": "https://api.z.ai/api/coding/paas/v4",
        "available_models": [
          {
            "name": "GLM-5.1",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          }
        ]
      },
      "opencode": {
        "api_url": "https://opencode.ai/zen/v1/chat/completions",
        "available_models": [
          {
            "name": "big-pickle",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          }
        ]
      }
    }
  },
  "server_url": "https://zed.dev",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "edit_predictions": {
    "provider": "none"
  },
  "base_keymap": "Atom",
  "icon_theme": "Zed (Default)",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "tab_size": 2,
  "preferred_line_length": 80,
  "soft_wrap": "bounded",
  "show_wrap_guides": true,
  "wrap_guides": [80, 100],
  "buffer_font_size": null,

  "buffer_font_family": "Monaco",
  "ui_font_fallbacks": ["Inter", ".SystemUIFont"],
  "ui_font_size": 16,
  "format_on_save": "on",
  "vim_mode": false,
  "projects_online_by_default": true,
  "terminal": {
    "font_family": "Monaco",
    "blinking": "off",
    "font_size": 16,
    "working_directory": "current_project_directory"
  },
  "auto_install_extensions": {
    "html": true,
    "astro": true,
    "atomize": true,
    "emmet": true,
    "env": true,
    "jsonnet": true,
    "solidity": true,
    "toml": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "use_autoclose": true,
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true
    }
  },
  "journal": {
    "path": "~",
    "hour_format": "hour12"
  },
  "calls": {
    "mute_on_join": true,
    "share_on_join": false
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "tailwindCSS.includeLanguages": {
    "plaintext": "html"
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/node_modules"
  ],
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "chat_panel": {
    "button": "never"
  },
  "notification_panel": {
    "button": false
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "openai",
      "model": "gpt-4o"
    }
  },
  "jupyter": {
    "kernel_selections": {
      "python": "conda-env",
      "typescript": "deno",
      "javascript": "deno"
    }
  }
}
