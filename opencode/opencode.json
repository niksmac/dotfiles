{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "darrenhinde/OpenAgentsControl",
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "compaction": {
    "auto": false,
    "prune": false,
    "reserved": 10000
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "formatter": true,
  "share": "disabled"
}
